CREATE PROCEDURE sp_GetNoShowReport
AS
BEGIN
    SET NOCOUNT ON;
    WITH Stats AS (
        SELECT
            u.UserID, u.FullName,
            COUNT(ra.ReservationID)                             AS TotalBookings,
            SUM(CASE WHEN ra.IsAttended = 0 THEN 1 ELSE 0 END) AS MissedCount,
            SUM(CASE WHEN ra.IsAttended = 1 THEN 1 ELSE 0 END) AS AttendedCount
        FROM Users u
        JOIN ReservationAttendees ra ON u.UserID = ra.UserID
        GROUP BY u.UserID, u.FullName
        HAVING COUNT(ra.ReservationID) >= 3
    )
    SELECT
        UserID, FullName, TotalBookings, AttendedCount, MissedCount,
        CAST(MissedCount * 100.0 / TotalBookings AS DECIMAL(5,2)) AS NoShowRate,
        CAST(PERCENT_RANK() OVER (ORDER BY MissedCount * 1.0 / TotalBookings) * 100 AS DECIMAL(5,2)) AS NoShowPercentile,
        CASE
            WHEN MissedCount * 1.0 / TotalBookings >= 0.5  THEN N'High Risk'
            WHEN MissedCount * 1.0 / TotalBookings >= 0.25 THEN N'Moderate Risk'
            ELSE N'Good Standing'
        END AS RiskLabel
    FROM Stats
    ORDER BY NoShowRate DESC;
END;
GO

CREATE PROCEDURE sp_SuggestAlternatives
    @TypeID INT, @Start DATETIME, @End DATETIME
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @ApprovedID INT = (SELECT StatusID FROM Statuses WHERE StatusName = N'Approved');
    WITH Conflicts AS (
        SELECT DISTINCT FacilityID FROM Reservations
        WHERE StatusID = @ApprovedID AND StartTime < @End AND EndTime > @Start
    ),
    LatestOccupancy AS (
        SELECT s.FacilityID, l.CurrentCount
        FROM Sensors s
        JOIN (
            SELECT SensorID, CurrentCount,
                   ROW_NUMBER() OVER (PARTITION BY SensorID ORDER BY LoggedAt DESC) AS rn
            FROM OccupancyLogs
        ) l ON s.SensorID = l.SensorID AND l.rn = 1
    )
    SELECT
        f.FacilityID, f.FacilityName, z.ZoneName, f.MaxCapacity,
        ISNULL(lo.CurrentCount, 0) AS CurrentOccupancy,
        CAST(ISNULL(lo.CurrentCount,0) * 100.0 / f.MaxCapacity AS DECIMAL(5,2)) AS OccupancyPct,
        RANK() OVER (ORDER BY ISNULL(lo.CurrentCount,0) ASC) AS SuggestionRank
    FROM Facilities f
    JOIN Zones z ON f.ZoneID = z.ZoneID
    LEFT JOIN LatestOccupancy lo ON f.FacilityID = lo.FacilityID
    WHERE f.TypeID = @TypeID AND f.IsReservable = 1 AND f.IsOperational = 1
      AND f.FacilityID NOT IN (SELECT FacilityID FROM Conflicts)
    ORDER BY SuggestionRank;
END;
GO

CREATE PROCEDURE sp_GetUsageByRole
AS
BEGIN
    SET NOCOUNT ON;
    SELECT
        ISNULL(ro.RoleName, N'ALL ROLES') AS RoleName,
        ISNULL(ft.TypeName, N'ALL TYPES') AS FacilityType,
        COUNT(r.ReservationID)            AS TotalBookings,
        SUM(DATEDIFF(MINUTE, r.StartTime, r.EndTime)) / 60.0 AS TotalReservedHours,
        AVG(DATEDIFF(MINUTE, r.StartTime, r.EndTime))         AS AvgDurationMin
    FROM Roles ro
    JOIN UserRoles     ur ON ro.RoleID    = ur.RoleID
    JOIN Users         u  ON ur.UserID   = u.UserID
    JOIN Reservations  r  ON u.UserID    = r.OrganizerUserID
    JOIN Facilities    f  ON r.FacilityID = f.FacilityID
    JOIN FacilityTypes ft ON f.TypeID    = ft.TypeID
    GROUP BY ROLLUP(ro.RoleName, ft.TypeName)
    ORDER BY ro.RoleName, ft.TypeName;
END;
GO

CREATE PROCEDURE sp_GetPeakHours
    @FacilityID INT
AS
BEGIN
    SET NOCOUNT ON;
    WITH HourlyAvg AS (
        SELECT
            DATEPART(HOUR, l.LoggedAt) AS HourOfDay,
            AVG(l.CurrentCount)        AS AvgOccupancy,
            MAX(l.CurrentCount)        AS PeakOccupancy,
            COUNT(*)                   AS SampleCount
        FROM OccupancyLogs l
        JOIN Sensors s ON l.SensorID = s.SensorID
        WHERE s.FacilityID = @FacilityID
        GROUP BY DATEPART(HOUR, l.LoggedAt)
    )
    SELECT
        HourOfDay, AvgOccupancy, PeakOccupancy, SampleCount,
        AvgOccupancy - LAG(AvgOccupancy, 1, AvgOccupancy)
            OVER (ORDER BY HourOfDay)                           AS DeltaFromPrevHour,
        LEAD(AvgOccupancy, 1, AvgOccupancy)
            OVER (ORDER BY HourOfDay) - AvgOccupancy           AS DeltaToNextHour,
        AVG(CAST(AvgOccupancy AS FLOAT))
            OVER (ORDER BY HourOfDay ROWS UNBOUNDED PRECEDING) AS RunningDayAvg,
        DENSE_RANK() OVER (ORDER BY AvgOccupancy DESC)         AS BusiestRank
    FROM HourlyAvg
    ORDER BY HourOfDay;
END;
GO

CREATE PROCEDURE sp_GetWeeklyTrend
    @FacilityID INT
AS
BEGIN
    SET NOCOUNT ON;
    WITH DailyAvg AS (
        SELECT
            CAST(l.LoggedAt AS DATE) AS LogDate,
            AVG(l.CurrentCount)      AS DailyAvg,
            MAX(l.CurrentCount)      AS DailyPeak
        FROM OccupancyLogs l
        JOIN Sensors s ON l.SensorID = s.SensorID
        WHERE s.FacilityID = @FacilityID
          AND l.LoggedAt  >= DATEADD(DAY, -7, CAST(GETDATE() AS DATE))
        GROUP BY CAST(l.LoggedAt AS DATE)
    )
    SELECT
        LogDate, DailyAvg, DailyPeak,
        AVG(CAST(DailyAvg AS FLOAT))
            OVER (ORDER BY LogDate ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS MovingAvg3Day,
        DailyAvg - LAG(DailyAvg, 1, DailyAvg) OVER (ORDER BY LogDate)       AS DayOverDayDelta
    FROM DailyAvg
    ORDER BY LogDate;
END;
GO

CREATE PROCEDURE sp_GetWeeklyUtilisationPivot
AS
BEGIN
    SET NOCOUNT ON;
    SELECT *
    FROM (
        SELECT
            f.FacilityName,
            DATENAME(WEEKDAY, l.LoggedAt) AS DayName,
            CAST(l.CurrentCount * 100.0 / f.MaxCapacity AS DECIMAL(5,2)) AS OccupancyPct
        FROM OccupancyLogs l
        JOIN Sensors    s ON l.SensorID   = s.SensorID
        JOIN Facilities f ON s.FacilityID = f.FacilityID
    ) AS Src
    PIVOT (
        AVG(OccupancyPct)
        FOR DayName IN ([Monday],[Tuesday],[Wednesday],[Thursday],[Friday],[Saturday],[Sunday])
    ) AS Pvt
    ORDER BY FacilityName;
END;
GO

CREATE PROCEDURE sp_GetZoneHierarchy
    @RootZoneID INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    WITH ZoneTree AS (
        SELECT ZoneID, ZoneName, ParentZoneID, 0 AS Depth,
               CAST(ZoneName AS NVARCHAR(500)) AS ZonePath
        FROM Zones
        WHERE (@RootZoneID IS NULL AND ParentZoneID IS NULL) OR ZoneID = @RootZoneID

        UNION ALL

        SELECT z.ZoneID, z.ZoneName, z.ParentZoneID, zt.Depth + 1,
               CAST(zt.ZonePath + N' > ' + z.ZoneName AS NVARCHAR(500))
        FROM Zones z
        JOIN ZoneTree zt ON z.ParentZoneID = zt.ZoneID
    )
    SELECT
        zt.ZoneID,
        REPLICATE(N'    ', zt.Depth) + zt.ZoneName AS IndentedName,
        zt.ZonePath, zt.Depth,
        COUNT(f.FacilityID)         AS FacilityCount,
        ISNULL(SUM(f.MaxCapacity), 0) AS TotalCapacity
    FROM ZoneTree zt
    LEFT JOIN Facilities f ON zt.ZoneID = f.ZoneID
    GROUP BY zt.ZoneID, zt.ZoneName, zt.ZonePath, zt.Depth
    ORDER BY zt.ZonePath;
END;
GO

CREATE PROCEDURE sp_FindFreeSlots
    @FacilityID INT, @Date DATE
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @OpenDT DATETIME, @CloseDT DATETIME, @ApprovedID INT;

    SELECT @OpenDT  = CAST(@Date AS DATETIME) + CAST(OpenTime  AS DATETIME),
           @CloseDT = CAST(@Date AS DATETIME) + CAST(CloseTime AS DATETIME)
    FROM Facilities WHERE FacilityID = @FacilityID;

    SELECT @ApprovedID = StatusID FROM Statuses WHERE StatusName = N'Approved';

    WITH Slots AS (
        SELECT @OpenDT AS SlotStart, DATEADD(HOUR,1,@OpenDT) AS SlotEnd
        UNION ALL
        SELECT DATEADD(HOUR,1,SlotStart), DATEADD(HOUR,1,SlotEnd)
        FROM Slots WHERE DATEADD(HOUR,1,SlotEnd) <= @CloseDT
    )
    SELECT sl.SlotStart, sl.SlotEnd, N'Available' AS Availability
    FROM Slots sl
    WHERE NOT EXISTS (
        SELECT 1 FROM Reservations r
        WHERE r.FacilityID = @FacilityID AND r.StatusID = @ApprovedID
          AND r.StartTime < sl.SlotEnd AND r.EndTime > sl.SlotStart
    )
    OPTION (MAXRECURSION 100);
END;
GO

CREATE PROCEDURE sp_GetUserDashboard
    @UserID INT
AS
BEGIN
    SET NOCOUNT ON;

    SELECT r.ReservationID, f.FacilityName, r.StartTime, r.EndTime, st.StatusName
    FROM Reservations r
    JOIN Facilities f  ON r.FacilityID = f.FacilityID
    JOIN Statuses   st ON r.StatusID   = st.StatusID
    WHERE r.OrganizerUserID = @UserID AND r.StartTime > GETDATE()
    ORDER BY r.StartTime;

    SELECT
        COUNT(*) AS TotalBookings,
        SUM(CASE WHEN ra.IsAttended = 1 THEN 1 ELSE 0 END) AS Attended,
        SUM(CASE WHEN ra.IsAttended = 0 THEN 1 ELSE 0 END) AS Missed,
        CAST(SUM(CASE WHEN ra.IsAttended = 1 THEN 1.0 ELSE 0 END) / NULLIF(COUNT(*),0) * 100 AS DECIMAL(5,2)) AS AttendanceRate
    FROM ReservationAttendees ra WHERE ra.UserID = @UserID;

    SELECT COUNT(*) AS ActivePenalties, SUM(PenaltyPoints) AS TotalPoints, MIN(ExpiresAt) AS EarliestExpiry
    FROM UserPenalties WHERE UserID = @UserID AND IsActive = 1;

    SELECT TOP 3 FacilityName, ZoneName, OccupancyPct, CrowdLevel
    FROM vw_LiveOccupancy ORDER BY OccupancyPct ASC;
END;
GO

