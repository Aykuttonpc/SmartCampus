GO

CREATE VIEW vw_LiveOccupancy
AS
WITH LatestPerSensor AS (
    SELECT
        SensorID,
        CurrentCount,
        LoggedAt,
        ROW_NUMBER() OVER (PARTITION BY SensorID ORDER BY LoggedAt DESC) AS rn
    FROM OccupancyLogs
)
SELECT
    f.FacilityID,
    f.FacilityName,
    z.ZoneName,
    ft.TypeName                                                              AS FacilityType,
    f.MaxCapacity,
    ISNULL(l.CurrentCount, 0)                                               AS LiveCount,
    CAST(ISNULL(l.CurrentCount, 0) * 100.0 / f.MaxCapacity AS DECIMAL(5,2)) AS OccupancyPct,
    l.LoggedAt                                                               AS LastUpdated,
    CASE WHEN ISNULL(l.CurrentCount,0) > f.MaxCapacity
         THEN CAST(1 AS BIT) ELSE CAST(0 AS BIT) END                        AS IsOverCapacity,
    CASE
        WHEN ISNULL(l.CurrentCount,0) = 0                          THEN N'Empty'
        WHEN ISNULL(l.CurrentCount,0) * 1.0 / f.MaxCapacity < 0.5 THEN N'Low'
        WHEN ISNULL(l.CurrentCount,0) * 1.0 / f.MaxCapacity < 0.8 THEN N'Moderate'
        WHEN ISNULL(l.CurrentCount,0) * 1.0 / f.MaxCapacity < 1.0 THEN N'High'
        ELSE N'Over Capacity'
    END                                                                      AS CrowdLevel
FROM Facilities    f
JOIN Zones         z  ON f.ZoneID     = z.ZoneID
JOIN FacilityTypes ft ON f.TypeID     = ft.TypeID
JOIN Sensors       s  ON f.FacilityID = s.FacilityID
LEFT JOIN LatestPerSensor l ON s.SensorID = l.SensorID AND l.rn = 1
WHERE f.IsOperational = 1;
GO

CREATE VIEW vw_TodayReservations
AS
SELECT
    r.ReservationID,
    f.FacilityName,
    u.FullName                                   AS Organizer,
    st.StatusName,
    r.StartTime,
    r.EndTime,
    DATEDIFF(MINUTE, r.StartTime, r.EndTime)     AS DurationMin,
    COUNT(ra.UserID)                             AS AttendeeCount
FROM Reservations              r
JOIN Facilities                f  ON r.FacilityID      = f.FacilityID
JOIN Users                     u  ON r.OrganizerUserID = u.UserID
JOIN Statuses                  st ON r.StatusID        = st.StatusID
LEFT JOIN ReservationAttendees ra ON r.ReservationID   = ra.ReservationID
WHERE CAST(r.StartTime AS DATE) = CAST(GETDATE() AS DATE)
GROUP BY r.ReservationID, f.FacilityName, u.FullName, st.StatusName, r.StartTime, r.EndTime;
GO

CREATE TRIGGER trg_AuditStatusChange
ON Reservations
AFTER UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    INSERT INTO ReservationAuditLog (ReservationID, OldStatusID, NewStatusID, ChangedAt)
    SELECT i.ReservationID, d.StatusID, i.StatusID, GETDATE()
    FROM inserted i
    JOIN deleted  d ON i.ReservationID = d.ReservationID
    WHERE i.StatusID <> d.StatusID;
END;
GO

CREATE TRIGGER trg_AutoNoShowPenalty
ON Reservations
AFTER UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    IF NOT EXISTS (
        SELECT 1 FROM inserted i
        JOIN deleted  d ON i.ReservationID = d.ReservationID
        JOIN Statuses s ON i.StatusID      = s.StatusID
        WHERE s.StatusName = N'Completed' AND i.StatusID <> d.StatusID
    ) RETURN;

    INSERT INTO UserPenalties (UserID, ReservationID, PenaltyPoints, ExpiresAt)
    SELECT ra.UserID, ra.ReservationID, 1, DATEADD(DAY, 30, GETDATE())
    FROM ReservationAttendees ra
    JOIN inserted             i ON ra.ReservationID = i.ReservationID
    WHERE ra.IsAttended = 0;
END;
GO

CREATE TRIGGER trg_BlockSuspendedUser
ON Reservations
INSTEAD OF INSERT
AS
BEGIN
    SET NOCOUNT ON;
    IF EXISTS (
        SELECT 1 FROM inserted i
        JOIN UserPenalties up ON i.OrganizerUserID = up.UserID
        WHERE up.IsActive = 1
        GROUP BY i.OrganizerUserID
        HAVING COUNT(*) >= 3
    )
    BEGIN
        RAISERROR(N'User is blocked due to repeated no-shows.', 16, 1);
        RETURN;
    END;
    INSERT INTO Reservations (FacilityID, OrganizerUserID, StatusID, StartTime, EndTime, CreatedAt)
    SELECT FacilityID, OrganizerUserID, StatusID, StartTime, EndTime, GETDATE()
    FROM inserted;
END;
GO

CREATE PROCEDURE sp_GetLiveHeatmap
AS
BEGIN
    SET NOCOUNT ON;
    WITH OccupancyBase AS (
        SELECT
            f.FacilityID, f.FacilityName, z.ZoneName, ft.TypeName AS FacilityType,
            f.MaxCapacity,
            ISNULL(l.CurrentCount, 0) AS LiveCount,
            CAST(ISNULL(l.CurrentCount,0) * 100.0 / f.MaxCapacity AS DECIMAL(5,2)) AS OccupancyPct
        FROM Facilities f
        JOIN Zones         z  ON f.ZoneID     = z.ZoneID
        JOIN FacilityTypes ft ON f.TypeID     = ft.TypeID
        JOIN Sensors       s  ON f.FacilityID = s.FacilityID
        LEFT JOIN (
            SELECT SensorID, CurrentCount,
                   ROW_NUMBER() OVER (PARTITION BY SensorID ORDER BY LoggedAt DESC) AS rn
            FROM OccupancyLogs
        ) l ON s.SensorID = l.SensorID AND l.rn = 1
        WHERE f.IsOperational = 1
    )
    SELECT
        FacilityID, FacilityName, ZoneName, FacilityType, MaxCapacity, LiveCount, OccupancyPct,
        DENSE_RANK() OVER (PARTITION BY ZoneName ORDER BY OccupancyPct DESC) AS ZoneRank,
        SUM(LiveCount)    OVER (PARTITION BY ZoneName)                        AS ZoneTotalPeople,
        AVG(OccupancyPct) OVER (PARTITION BY ZoneName)                        AS ZoneAvgOccupancyPct,
        OccupancyPct - AVG(OccupancyPct) OVER (PARTITION BY ZoneName)        AS DiffFromZoneAvg
    FROM OccupancyBase
    ORDER BY ZoneName, ZoneRank;
END;
