@model SmartCampus.Models.PaginatedList<SmartCampus.Models.TodayReservationVm>
@{ ViewData["Title"] = "Bugünün Takvimi"; }

<div class="page-header">
    <h1>📅 Bugünün Rezervasyonları</h1>
    <span class="updated-at">@DateTime.Today.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</span>
</div>

<div class="filter-wrap" style="margin-bottom: 20px;">
    <form method="get" asp-action="Index" class="filter-form" style="display: flex; gap: 10px; align-items: center;">
        <input type="text" name="searchString" placeholder="Mekan veya Organizatör ara..." value="@ViewBag.SearchString" class="form-control" style="max-width: 300px;" />
        
        <select name="statusFilter" class="form-select" style="max-width: 200px;">
            @if(string.IsNullOrEmpty(ViewBag.StatusFilter)) { <option value="" selected>Tüm Durumlar</option> } else { <option value="">Tüm Durumlar</option> }
            @if(ViewBag.StatusFilter == "Pending") { <option value="Pending" selected>Bekliyor</option> } else { <option value="Pending">Bekliyor</option> }
            @if(ViewBag.StatusFilter == "Approved") { <option value="Approved" selected>Onaylandı</option> } else { <option value="Approved">Onaylandı</option> }
            @if(ViewBag.StatusFilter == "Cancelled") { <option value="Cancelled" selected>İptal Edildi</option> } else { <option value="Cancelled">İptal Edildi</option> }
            @if(ViewBag.StatusFilter == "Completed") { <option value="Completed" selected>Tamamlandı</option> } else { <option value="Completed">Tamamlandı</option> }
        </select>
        
        <button type="submit" class="btn btn-primary">Filtrele</button>
        <a asp-action="Index" class="btn btn-secondary">Temizle</a>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">Bugün için henüz rezervasyon yok.</div>
}
else
{
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>#</th><th>Mekan</th><th>Organizatör</th>
                    <th>Başlangıç</th><th>Bitiş</th><th>Süre</th>
                    <th>Katılımcı</th><th>Durum</th><th>İşlem</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.ReservationID</td>
                    <td>@r.FacilityName</td>
                    <td>@r.Organizer</td>
                    <td>@r.StartTime.ToString("HH:mm")</td>
                    <td>@r.EndTime.ToString("HH:mm")</td>
                    <td>@r.DurationMin dk</td>
                    <td>@r.AttendeeCount kişi</td>
                    <td><span class="status-badge status-@r.StatusName.ToLower()">@r.StatusName</span></td>
                    <td>
                        @{
                            var roles = Context.Session.GetString("Roles") ?? "";
                            bool isAdminOrStaff = roles.Contains("Admin") || roles.Contains("Staff");
                        }
                        @if (r.StatusName == "Pending" && isAdminOrStaff)
                        {
                            <form asp-action="Approve" asp-route-id="@r.ReservationID" method="post" style="display:inline">
                                <button class="btn btn-primary btn-sm">Onayla</button>
                            </form>
                        }
                        @if (r.StatusName is "Pending" or "Approved")
                        {
                            var sessionUid = Context.Session.GetInt32("UserID");
                            if (isAdminOrStaff || sessionUid == r.OrganizerUserID)
                            {
                                <form asp-action="Cancel" asp-route-id="@r.ReservationID" method="post" style="display:inline"
                                      onsubmit="return confirm('İptal edilsin mi?')">
                                    <button class="btn btn-danger btn-sm">İptal</button>
                                </form>
                            }
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="pagination-container" style="margin-top: 20px; text-align: center;">
        @if (Model.HasPreviousPage)
        {
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-searchString="@ViewBag.SearchString" asp-route-statusFilter="@ViewBag.StatusFilter" class="btn btn-secondary">Önceki</a>
        }
        
        <span style="margin: 0 15px;">Sayfa @Model.PageIndex / @Model.TotalPages</span>
        
        @if (Model.HasNextPage)
        {
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-searchString="@ViewBag.SearchString" asp-route-statusFilter="@ViewBag.StatusFilter" class="btn btn-primary">Sonraki</a>
        }
    </div>
}
