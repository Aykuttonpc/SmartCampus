@model List<SmartCampus.Models.FreeSlotVm>
@{ ViewData["Title"] = "Rezervasyon Yap"; }

<div class="page-header">
    <h1>🕐 Boş Zaman Dilimleri</h1>
    <p>Mekan ID: <strong>@ViewBag.FacilityId</strong> · Tarih: <strong>@ViewBag.Date</strong></p>
</div>

@if (!Model.Any())
{
    <div class="empty-state">Seçilen tarihte uygun slot bulunamadı.</div>
}
else
{
    <div class="slots-grid">
        @foreach (var s in Model)
        {
            <form asp-action="Confirm" method="post" class="slot-form">
                <input type="hidden" name="FacilityID" value="@ViewBag.FacilityId" />
                <input type="hidden" name="SlotStart" value="@s.SlotStart.ToString("o")" />
                <input type="hidden" name="SlotEnd"   value="@s.SlotEnd.ToString("o")" />
                <button type="submit" class="slot-card">
                    <span class="slot-time">@s.SlotStart.ToString("HH:mm") – @s.SlotEnd.ToString("HH:mm")</span>
                    <span class="slot-available">✓ Uygun</span>
                </button>
            </form>
        }
    </div>
}
<a asp-action="Index" class="btn btn-secondary" style="margin-top:1.5rem">← Takvime Dön</a>
