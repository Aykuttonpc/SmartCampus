@model List<SmartCampus.Models.LiveOccupancyVm>
@{ ViewData["Title"] = "Dashboard"; }

<div class="page-header">
    <h1>Kampüs Doluluk Durumu</h1>
    <span class="updated-at">Son güncelleme: @DateTime.Now.ToString("HH:mm")</span>
</div>

<div class="occupancy-grid">
    @foreach (var f in Model)
    {
        var cls = f.CrowdLevel switch
        {
            "Empty"        => "level-empty",
            "Low"          => "level-low",
            "Moderate"     => "level-moderate",
            "High"         => "level-high",
            _              => "level-over"
        };
        <div class="facility-card @cls">
            <div class="card-header">
                <span class="facility-name">@f.FacilityName</span>
                <span class="crowd-badge">@f.CrowdLevel</span>
            </div>
            <div class="card-body">
                <div class="zone-tag">📍 @f.ZoneName · @f.FacilityType</div>
                <div class="count-display">
                    <span class="live-count">@f.LiveCount</span>
                    <span class="max-cap">/ @f.MaxCapacity kişi</span>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar" style="width:@(Math.Min(f.OccupancyPct,100))%"></div>
                </div>
                <div class="pct-label">%@f.OccupancyPct doluluk</div>
            </div>
            <div class="card-footer">
                @if (f.IsReservable)
                {
                    <a asp-controller="Reservations" asp-action="Book"
                       asp-route-facilityId="@f.FacilityID" class="btn btn-primary">Rezervasyon Yap</a>
                }
                @if (f.OccupancyPct >= 80)
                {
                    <a asp-controller="Reservations" asp-action="Alternatives"
                       asp-route-typeName="@f.FacilityType" class="btn btn-secondary">Alternatif Bul</a>
                }
                @if (f.LastUpdated.HasValue)
                {
                    <span class="last-update">@f.LastUpdated.Value.ToString("HH:mm")'de güncellendi</span>
                }
            </div>
        </div>
    }
</div>
