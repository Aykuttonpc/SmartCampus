@model List<SmartCampus.Models.LiveOccupancyVm>
@{ ViewData["Title"] = "Dashboard"; }

<div class="page-header">
    <h1>Kampüs Doluluk Durumu</h1>
    <span class="updated-at">Son güncelleme: @DateTime.Now.ToString("HH:mm")</span>
</div>

<div class="occupancy-grid">
    @foreach (var f in Model)
    {
        var cls = f.CrowdLevel switch
        {
            "Empty"        => "level-empty",
            "Low"          => "level-low",
            "Moderate"     => "level-moderate",
            "High"         => "level-high",
            _              => "level-over"
        };
        <div class="facility-card @cls" id="card-@f.FacilityID">
            <div class="card-header">
                <span class="facility-name">@f.FacilityName</span>
                <span class="crowd-badge">@f.CrowdLevel</span>
            </div>
            <div class="card-body">
                <div class="zone-tag">📍 @f.ZoneName · @f.FacilityType</div>
                <div class="count-display">
                    <span class="live-count">@f.LiveCount</span>
                    <span class="max-cap">/ @f.MaxCapacity kişi</span>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar" style="width:@(Math.Min(f.OccupancyPct,100))%"></div>
                </div>
                <div class="pct-label">%@f.OccupancyPct doluluk</div>
            </div>
            <div class="card-footer">
                @if (f.IsReservable)
                {
                    <a asp-controller="Reservations" asp-action="Book"
                       asp-route-facilityId="@f.FacilityID" class="btn btn-primary">Rezervasyon Yap</a>
                }
                @if (f.OccupancyPct >= 80)
                {
                    <a asp-controller="Reservations" asp-action="Alternatives"
                       asp-route-typeName="@f.FacilityType" class="btn btn-secondary">Alternatif Bul</a>
                }
                <span class="last-update" id="time-@f.FacilityID">@(f.LastUpdated.HasValue ? f.LastUpdated.Value.ToString("HH:mm") + "'de güncellendi" : "")</span>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/occupancyHub")
            .build();

        connection.on("UpdateOccupancy", (data) => {
            const card = document.getElementById("card-" + data.facilityId);
            if (!card) return;

            // DOM Güncellemeleri
            card.className = "facility-card level-" + data.crowdLevel.toLowerCase();
            card.querySelector(".crowd-badge").innerText = data.crowdLevel;
            card.querySelector(".live-count").innerText = data.liveCount;
            card.querySelector(".progress-bar").style.width = Math.min(data.occupancyPct, 100) + "%";
            card.querySelector(".pct-label").innerText = "%" + data.occupancyPct + " doluluk";
            
            const timeSpan = document.getElementById("time-" + data.facilityId);
            if (timeSpan) {
                timeSpan.innerText = Array.from(timeSpan.childNodes).some(n => n.nodeType === 3) 
                    ? data.lastUpdated + "'de güncellendi" 
                    : "";
            }

            // Animasyon detayı
            card.style.transform = "scale(1.02)";
            card.style.boxShadow = "0 0 15px rgba(0, 200, 83, 0.4)";
            setTimeout(() => {
                card.style.transform = "scale(1)";
                card.style.boxShadow = "";
            }, 600);
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
}
