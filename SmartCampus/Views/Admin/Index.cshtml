@model SmartCampus.Models.PaginatedList<SmartCampus.Models.NoShowReportVm>
@{ ViewData["Title"] = "Admin Panel"; }

<div class="page-header">
    <h1>⚙️ Admin – No-Show Raporu</h1>
</div>

<div class="filter-wrap" style="margin-bottom: 20px;">
    <form method="get" asp-action="Index" class="filter-form" style="display: flex; gap: 10px; align-items: center;">
        <input type="text" name="searchString" placeholder="Kullanıcı adı ara..." value="@ViewBag.SearchString" class="form-control" style="max-width: 300px;" />
        
        <select name="riskFilter" class="form-select" style="max-width: 200px;">
            @if(string.IsNullOrEmpty(ViewBag.RiskFilter)) { <option value="" selected>Tüm Riskler</option> } else { <option value="">Tüm Riskler</option> }
            @if(ViewBag.RiskFilter == "High Risk") { <option value="High Risk" selected>Yüksek Risk</option> } else { <option value="High Risk">Yüksek Risk</option> }
            @if(ViewBag.RiskFilter == "Moderate Risk") { <option value="Moderate Risk" selected>Orta Risk</option> } else { <option value="Moderate Risk">Orta Risk</option> }
            @if(ViewBag.RiskFilter == "Good Standing") { <option value="Good Standing" selected>İyi Durum</option> } else { <option value="Good Standing">İyi Durum</option> }
        </select>
        
        <button type="submit" class="btn btn-primary">Filtrele</button>
        <a asp-action="Index" class="btn btn-secondary">Temizle</a>
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">Yeterli veri yok (en az 3 rezervasyon gerekli).</div>
}
else
{
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Kullanıcı</th><th>Toplam</th><th>Katıldı</th>
                    <th>Gelmedi</th><th>No-Show %</th><th>Risk</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.FullName</td>
                    <td>@r.TotalBookings</td>
                    <td>@r.AttendedCount</td>
                    <td>@r.MissedCount</td>
                    <td>%@r.NoShowRate</td>
                    <td>
                        <span class="risk-badge risk-@r.RiskLabel.ToLower().Replace(" ", "-")">
                            @r.RiskLabel
                        </span>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>

    <div class="pagination-container" style="margin-top: 20px; text-align: center;">
        @if (Model.HasPreviousPage)
        {
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" asp-route-searchString="@ViewBag.SearchString" asp-route-riskFilter="@ViewBag.RiskFilter" class="btn btn-secondary">Önceki</a>
        }
        
        <span style="margin: 0 15px;">Sayfa @Model.PageIndex / @Model.TotalPages</span>
        
        @if (Model.HasNextPage)
        {
            <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" asp-route-searchString="@ViewBag.SearchString" asp-route-riskFilter="@ViewBag.RiskFilter" class="btn btn-primary">Sonraki</a>
        }
    </div>
}
<a asp-action="Facilities" class="btn btn-secondary" style="margin-top:1rem">🏢 Mekan Yönetimi</a>
