@model SmartCampus.Models.PaginatedList<SmartCampus.Models.Facility>
@{ ViewData["Title"] = "Mekan Yönetimi"; }

<div class="page-header">
    <h1>🏢 Mekan Yönetimi</h1>
</div>

<div class="table-wrap">
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th><th>Mekan Adı</th><th>Bölge</th><th>Tür</th>
                <th>Kapasite</th><th>Rezerve</th><th>Operasyonel</th><th>İşlem</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>@f.FacilityID</td>
                <td>@f.FacilityName</td>
                <td>@f.Zone?.ZoneName</td>
                <td>@f.FacilityType?.TypeName</td>
                <td>@f.MaxCapacity</td>
                <td>@(f.IsReservable ? "✅" : "➖")</td>
                <td>@(f.IsOperational ? "✅" : "❌")</td>
                <td>
                    <form asp-action="DeleteFacility" asp-route-id="@f.FacilityID" method="post"
                          onsubmit="return confirm('@f.FacilityName silinsin mi?')">
                        <button class="btn btn-danger btn-sm">Sil</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

<div class="pagination-container" style="margin-top: 20px; text-align: center;">
    @if (Model.HasPreviousPage)
    {
        <a asp-action="Facilities" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn btn-secondary">Önceki</a>
    }
    
    <span style="margin: 0 15px;">Sayfa @Model.PageIndex / @Model.TotalPages</span>
    
    @if (Model.HasNextPage)
    {
        <a asp-action="Facilities" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn btn-primary">Sonraki</a>
    }
</div>
