@{ ViewData["Title"] = "Giriş Yap"; Layout = null; }
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SmartCampus – Giriş</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="login-body">
<div class="login-card">
    <div class="login-logo">🏛️</div>
    <h1 class="login-title">SmartCampus</h1>
    <p class="login-sub">Kampüs Doluluk ve Rezervasyon Sistemi</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error">@ViewBag.Error</div>
    }

    <form method="post" asp-action="Login">
        <div class="form-group">
            <label>E-posta</label>
            <input type="email" name="email" placeholder="ornek@uni.edu" required />
        </div>
        <div class="form-group">
            <label>Şifre</label>
            <input type="password" name="password" placeholder="••••••••" required />
        </div>
        <button type="submit" class="btn btn-primary btn-full">Giriş Yap</button>
    </form>
    <p class="login-hint">Demo: <code>kaan1@uni.edu</code> / <code>Campus123!</code></p>
    <p class="login-hint">Hesabın yok mu? <a href="/Account/Register">Kayıt Ol</a></p>
</div>
</body>
</html>
